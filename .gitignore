# ============================================================================
# 📁 .gitignore — Tells Git which files/folders to IGNORE (not track)
# ============================================================================
# These files will NOT be pushed to GitHub. This is critical for security
# and keeping the repository clean.
#
# TOPIC: Version Control — Managing what gets tracked and shared
# WHY: Some files should never be in a public repo:
#   - node_modules: Too large (hundreds of MB), can be reinstalled
#   - .env: Contains passwords, API keys, secrets
#   - dist/build: Generated files, can be rebuilt
# ============================================================================

# Dependencies — installed via 'npm install', no need to track
node_modules

# Environment variables — contains secrets (DB passwords, API keys, JWT secret)
# NEVER push .env to GitHub! Anyone could steal your credentials.
.env

# Build output (generated by 'npm run build')
dist
build

# OS-generated files
.DS_Store
Thumbs.db

# IDE/Editor files
.vscode
.idea